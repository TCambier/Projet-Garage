<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Global surfaces -->
  <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F5F6FA"/>
  <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
  <SolidColorBrush x:Key="SurfaceAltBrush" Color="#F9FAFB"/>

  <!-- Sidebar -->
  <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#111827"/>
  <SolidColorBrush x:Key="SidebarBrandCircleBrush" Color="#1F2937"/>
  <SolidColorBrush x:Key="SidebarTextBrush" Color="#FFFFFF"/>
  <SolidColorBrush x:Key="SidebarMutedTextBrush" Color="#9CA3AF"/>
  <SolidColorBrush x:Key="SidebarHoverBrush" Color="#1F4068"/>

  <!-- Text -->
  <SolidColorBrush x:Key="TextPrimaryBrush" Color="#111827"/>
  <SolidColorBrush x:Key="TextSecondaryBrush" Color="#6B7280"/>

  <!-- Misc -->
  <SolidColorBrush x:Key="AvatarBackgroundBrush" Color="#E5E7EB"/>
  <SolidColorBrush x:Key="AvatarTextBrush" Color="#4B5563"/>
  <SolidColorBrush x:Key="DangerSurfaceBrush" Color="#FEE2E2"/>
  <SolidColorBrush x:Key="DangerTextBrush" Color="#B91C1C"/>

  <SolidColorBrush x:Key="AccentBrush" Color="#2563EB"/>
  <SolidColorBrush x:Key="SuccessBrush" Color="#16A34A"/>
  <SolidColorBrush x:Key="DangerBrush" Color="#DC2626"/>

  <SolidColorBrush x:Key="OverlayBrush" Color="#80000000"/>
  <SolidColorBrush x:Key="BorderBrush" Color="#D1D5DB"/>
  <SolidColorBrush x:Key="FieldLabelBrush" Color="#374151"/>

  <!-- Lists -->
  <SolidColorBrush x:Key="ListItemBackgroundBrush" Color="#F9FAFB"/>
  <SolidColorBrush x:Key="ListItemHoverBrush" Color="#E5F1FF"/>
  <SolidColorBrush x:Key="ListItemSelectedBrush" Color="#DBEAFE"/>
</ResourceDictionary>
