<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Fond général de l'application -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F3F4F6"/>

    <!-- Surface principale (carte blanche) -->
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="#F9FAFB"/>

    <!-- Texte -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#111827"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#6B7280"/>

    <!-- Sidebar -->
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#1E293B"/>
    <SolidColorBrush x:Key="SidebarTextBrush" Color="#F1F5F9"/>
    <SolidColorBrush x:Key="SidebarMutedTextBrush" Color="#94A3B8"/>
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="#334155"/>
    <SolidColorBrush x:Key="SidebarBrandCircleBrush" Color="#3B82F6"/>

    <!-- Avatar -->
    <SolidColorBrush x:Key="AvatarBackgroundBrush" Color="#DBEAFE"/>
    <SolidColorBrush x:Key="AvatarTextBrush" Color="#1D4ED8"/>

    <!-- Danger -->
    <SolidColorBrush x:Key="DangerSurfaceBrush" Color="#FEE2E2"/>
    <SolidColorBrush x:Key="DangerTextBrush" Color="#B91C1C"/>

    <!-- Overlay (pour dialogs/popups) -->
    <SolidColorBrush x:Key="OverlayBrush" Color="#80000000"/>

    <!-- Listes -->
    <SolidColorBrush x:Key="ListItemBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ListItemHoverBrush" Color="#F3F4F6"/>
    <SolidColorBrush x:Key="ListItemSelectedBrush" Color="#DBEAFE"/>

</ResourceDictionary>
