<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Fond général de l'application -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#0F172A"/>

    <!-- Surface principale -->
    <SolidColorBrush x:Key="SurfaceBrush" Color="#1E293B"/>
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="#334155"/>

    <!-- Texte -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F1F5F9"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#94A3B8"/>

    <!-- Sidebar -->
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#0F172A"/>
    <SolidColorBrush x:Key="SidebarTextBrush" Color="#F1F5F9"/>
    <SolidColorBrush x:Key="SidebarMutedTextBrush" Color="#64748B"/>
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="#1E293B"/>
    <SolidColorBrush x:Key="SidebarBrandCircleBrush" Color="#2563EB"/>

    <!-- Avatar -->
    <SolidColorBrush x:Key="AvatarBackgroundBrush" Color="#1E3A5F"/>
    <SolidColorBrush x:Key="AvatarTextBrush" Color="#93C5FD"/>

    <!-- Danger -->
    <SolidColorBrush x:Key="DangerSurfaceBrush" Color="#450A0A"/>
    <SolidColorBrush x:Key="DangerTextBrush" Color="#FCA5A5"/>

    <!-- Overlay (pour dialogs/popups) -->
    <SolidColorBrush x:Key="OverlayBrush" Color="#CC000000"/>

    <!-- Listes -->
    <SolidColorBrush x:Key="ListItemBackgroundBrush" Color="#1E293B"/>
    <SolidColorBrush x:Key="ListItemHoverBrush" Color="#334155"/>
    <SolidColorBrush x:Key="ListItemSelectedBrush" Color="#1E3A5F"/>

</ResourceDictionary>
