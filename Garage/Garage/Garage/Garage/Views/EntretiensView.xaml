<Page x:Class="Garage.Views.EntretiensView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:vm="clr-namespace:Garage.ViewModels"
      xmlns:h="clr-namespace:Garage.Helpers"
      mc:Ignorable="d"
      Background="{DynamicResource AppBackgroundBrush}">

    <Page.DataContext>
        <vm:EntretiensViewModel />
    </Page.DataContext>

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <h:MaintenanceStatusToVisibilityConverter x:Key="MaintenanceStatusToVisibilityConverter" />
    </Page.Resources>

    <!-- Conteneur principal avec overlay pour popup -->
    <Grid Margin="24">
        <!-- Carte blanche principale -->
        <Border Background="{DynamicResource SurfaceBrush}"
                CornerRadius="24"
                Effect="{DynamicResource SoftShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- === SIDEBAR === -->
                <Border Grid.Column="0"
                        Background="{DynamicResource SidebarBackgroundBrush}"
                        CornerRadius="24 0 0 24">
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Logo appli -->
                        <StackPanel Orientation="Horizontal" Grid.Row="0" VerticalAlignment="Center">
                            <Border Width="32" Height="32" CornerRadius="16" Background="{DynamicResource SidebarBrandCircleBrush}" Margin="0,0,8,0">
                                <TextBlock Text="🚗" Foreground="{DynamicResource SidebarTextBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="16"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="AutoMaint Pro" Foreground="{DynamicResource SidebarTextBrush}" FontSize="18" FontWeight="Bold"/>
                                <TextBlock Text="Garage" Foreground="{DynamicResource SidebarMutedTextBrush}" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Menu -->
                        <StackPanel Grid.Row="1" Margin="0,32,0,0">
                            <Button Style="{StaticResource SidebarButton}"
                                    Command="{Binding NavigateToDashboardCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Dashboard"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButton}"
                                    Command="{Binding NavigateToVehiculesCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Véhicules"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButton}" Background="#1f4068">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Entretiens"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Alertes"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButton}" Command="{Binding NavigateToStatistiquesCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Statistiques"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButton}" Command="{Binding NavigateToSettingsCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Paramètres"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Profil -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,16,0,0">
                            <Border Width="40" Height="40" CornerRadius="20" Background="{DynamicResource SidebarBrandCircleBrush}" Margin="0,0,10,0">
                                <TextBlock Text="JD" Foreground="{DynamicResource SidebarTextBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="Jean Dupont" Foreground="{DynamicResource SidebarTextBrush}" FontWeight="Bold"/>
                                <TextBlock Text="Patron" Foreground="{DynamicResource SidebarMutedTextBrush}" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- === CONTENU PRINCIPAL === -->
                <Grid Grid.Column="1" Margin="32">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Barre de titre + bouton ajouter -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Entretiens"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>

                        <Button Grid.Column="1"
                                Content="Ajouter un entretien"
                                Command="{Binding AddMaintenanceCommand}"
                                Background="#2563EB"
                                Foreground="White"
                                Padding="12 6"
                                Margin="16 0 0 0"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Cursor="Hand"/>
                    </Grid>

                    <!-- Tableau des entretiens -->
                    <Border Grid.Row="1"
                            Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="18"
                            Margin="0,24,0,0"
                            Effect="{DynamicResource SoftShadow}">
                        <ListView ItemsSource="{Binding Maintenances}"
                                  SelectedItem="{Binding SelectedMaintenance, Mode=TwoWay}"
                                  BorderThickness="0"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.Resources>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Margin" Value="0 4"/>
                                    <Setter Property="Padding" Value="16 12"/>
                                    <Setter Property="Background" Value="{DynamicResource ListItemBackgroundBrush}"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource ListItemHoverBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource ListItemSelectedBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListView.Resources>

                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Immatriculation" Width="200">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Immatriculation}" FontWeight="SemiBold"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="Entretien" Width="220">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Type}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="Pièces" Width="260">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Pieces}" TextTrimming="CharacterEllipsis"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="Date" Width="140">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DateIntervention, StringFormat={}{0:dd/MM/yyyy}}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="Statut" Width="120">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Statut}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <!-- Boutons d'actions -->
                                    <GridViewColumn Header="Actions" Width="260">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <!-- Terminer (met la date à aujourd'hui) -->
                                                    <Button Content="Terminer"
                                                            Command="{Binding DataContext.MarkAsDoneTodayCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                            CommandParameter="{Binding}"
                                                            Visibility="{Binding ., Converter={StaticResource MaintenanceStatusToVisibilityConverter}}"
                                                            Background="#16A34A"
                                                            Foreground="White"
                                                            Padding="8 4"
                                                            Margin="0 0 8 0"
                                                            BorderThickness="0"
                                                            Cursor="Hand"/>
                                                    <Button Content="Modifier"
                                                            Command="{Binding DataContext.EditMaintenanceCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                            CommandParameter="{Binding}"
                                                            Visibility="{Binding ., Converter={StaticResource MaintenanceStatusToVisibilityConverter}}"
                                                            Background="#2563EB"
                                                            Foreground="White"
                                                            Padding="8 4"
                                                            Margin="0 0 8 0"
                                                            BorderThickness="0"
                                                            Cursor="Hand"/>
                                                    <Button Content="Supprimer"
                                                            Command="{Binding DataContext.DeleteMaintenanceCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                            CommandParameter="{Binding}"
                                                            Visibility="{Binding ., Converter={StaticResource MaintenanceStatusToVisibilityConverter}}"
                                                            Background="#DC2626"
                                                            Foreground="White"
                                                            Padding="8 4"
                                                            Margin="0 0 0 0"
                                                            BorderThickness="0"
                                                            Cursor="Hand"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- POPUP AJOUT ENTRETIEN -->
        <Grid Visibility="{Binding IsAddDialogOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Rectangle Fill="{DynamicResource OverlayBrush}" />
            <Border Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="16"
                    Padding="24"
                    Width="450"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Effect="{DynamicResource SoftShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Nouvel entretien" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                    <StackPanel Grid.Row="1" Margin="0,0,0,16">
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Immatriculation *" Foreground="#374151" FontWeight="Medium" Margin="0,0,0,4"/>
                            <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8">
                                <ComboBox ItemsSource="{Binding AvailableVehicles}"
                                          SelectedItem="{Binding SelectedVehicleForNewMaintenance, Mode=TwoWay}"
                                          DisplayMemberPath="Immatriculation"
                                          FontSize="14" Padding="4" BorderThickness="0"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Type d'entretien *" Foreground="#374151" FontWeight="Medium" Margin="0,0,0,4"/>
                            <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8">
                                <TextBox Text="{Binding NewMaintenance.Type, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="12 10" BorderThickness="0"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Pièces (en stock)" Foreground="#374151" FontWeight="Medium" Margin="0,0,0,4"/>

                            <!-- Sélection d'une pièce + quantité -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8">
                                    <ComboBox ItemsSource="{Binding AvailablePieces}"
                                              SelectedItem="{Binding SelectedPieceForNewMaintenance, Mode=TwoWay}"
                                              DisplayMemberPath="Display"
                                              FontSize="14" Padding="4" BorderThickness="0"/>
                                </Border>

                                <Border Grid.Column="1" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Margin="8,0,0,0">
                                    <TextBox Text="{Binding QuantityForNewPiece, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="14" Padding="12 10" BorderThickness="0"/>
                                </Border>

                                <Button Grid.Column="2"
                                        Content="Ajouter"
                                        Command="{Binding AddPieceToNewMaintenanceCommand}"
                                        Background="#111827"
                                        Foreground="White"
                                        Padding="12 8"
                                        Margin="8,0,0,0"
                                        BorderThickness="0"
                                        Cursor="Hand"/>
                            </Grid>

                            <!-- Liste des pièces ajoutées -->
                            <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8">
                                <ListView ItemsSource="{Binding NewMaintenancePieces}"
                                          BorderThickness="0"
                                          Height="110"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Pièce" Width="190" DisplayMemberBinding="{Binding Piece.Libelle}"/>
                                            <GridViewColumn Header="Qté" Width="45" DisplayMemberBinding="{Binding Quantite}"/>
                                            <GridViewColumn Header="PU" Width="70">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding PrixUnite, StringFormat={}{0:0.00} €}"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Header="Total" Width="75">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Total, StringFormat={}{0:0.00} €}"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Width="50">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Content="X"
                                                                Padding="6 2"
                                                                Background="#DC2626"
                                                                Foreground="White"
                                                                BorderThickness="0"
                                                                Cursor="Hand"
                                                                Command="{Binding DataContext.RemovePieceFromNewMaintenanceCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                                CommandParameter="{Binding}"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </Border>

                            <TextBlock Margin="0,6,0,0"
                                       Foreground="#6B7280"
                                       FontSize="12"
                                       Text="{Binding NewPiecesTotal, StringFormat=Coût minimum (pièces) : {0:0.00} €}"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Date d'intervention" Foreground="#374151" FontWeight="Medium" Margin="0,0,0,4"/>
                            <DatePicker SelectedDate="{Binding NewMaintenance.DateIntervention, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Kilométrage" Foreground="#374151" FontWeight="Medium" Margin="0,0,0,4"/>
                            <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8">
                                <TextBox Text="{Binding NewMaintenance.Kilometrage, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="12 10" BorderThickness="0"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Coût" Foreground="#374151" FontWeight="Medium" Margin="0,0,0,4"/>
                            <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8">
                                <TextBox Text="{Binding NewMaintenance.Cout, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="12 10" BorderThickness="0"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Prix" Foreground="#374151" FontWeight="Medium" Margin="0,0,0,4"/>
                            <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8">
                                <TextBox Text="{Binding NewMaintenance.Prix, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="12 10" BorderThickness="0"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Annuler" Command="{Binding CancelNewMaintenanceCommand}" Margin="0,0,12,0" Padding="12,8" Background="Transparent" BorderBrush="#D1D5DB" Foreground="#374151"/>
                        <Button Content="Enregistrer" Command="{Binding SaveNewMaintenanceCommand}" Padding="12,8" Background="#2563EB" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- POPUP EDIT ENTRETIEN -->
        <Grid Visibility="{Binding IsEditDialogOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Rectangle Fill="{DynamicResource OverlayBrush}" />
            <Border Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="16"
                    Padding="24"
                    Width="450"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Effect="{DynamicResource SoftShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Modifier l'entretien" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                    <StackPanel Grid.Row="1" Margin="0,0,0,16">
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Immatriculation *" Foreground="#374151" FontWeight="Medium" Margin="0,0,0,4"/>
                            <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8">
                                <TextBox Text="{Binding EditMaintenance.Immatriculation, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="12 10" BorderThickness="0"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Type d'entretien *" Foreground="#374151" FontWeight="Medium" Margin="0,0,0,4"/>
                            <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8">
                                <TextBox Text="{Binding EditMaintenance.Type, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="12 10" BorderThickness="0"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Pièces utilisées" Foreground="#374151" FontWeight="Medium" Margin="0,0,0,4"/>
                            <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8">
                                <TextBox Text="{Binding EditMaintenance.Pieces}"
                                         FontSize="14"
                                         Padding="12 10"
                                         BorderThickness="0"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         MinHeight="60"
                                         TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Date d'intervention" Foreground="#374151" FontWeight="Medium" Margin="0,0,0,4"/>
                            <DatePicker SelectedDate="{Binding EditMaintenance.DateIntervention, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Statut" Foreground="#374151" FontWeight="Medium" Margin="0,0,0,4"/>
                            <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8">
                                <ComboBox SelectedValue="{Binding EditMaintenance.Statut, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Content"
                                          FontSize="14" Padding="4" BorderThickness="0">
                                    <ComboBoxItem Content="En Cours" />
                                    <ComboBoxItem Content="Terminé" />
                                </ComboBox>
                            </Border>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Kilométrage" Foreground="#374151" FontWeight="Medium" Margin="0,0,0,4"/>
                            <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8">
                                <TextBox Text="{Binding EditMaintenance.Kilometrage, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="12 10" BorderThickness="0"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Coût" Foreground="#374151" FontWeight="Medium" Margin="0,0,0,4"/>
                            <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8">
                                <TextBox Text="{Binding EditMaintenance.Cout, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="12 10" BorderThickness="0"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Prix" Foreground="#374151" FontWeight="Medium" Margin="0,0,0,4"/>
                            <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8">
                                <TextBox Text="{Binding EditMaintenance.Prix, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="12 10" BorderThickness="0"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Annuler" Command="{Binding CancelEditMaintenanceCommand}" Margin="0,0,12,0" Padding="12,8" Background="Transparent" BorderBrush="#D1D5DB" Foreground="#374151"/>
                        <Button Content="Enregistrer" Command="{Binding SaveEditMaintenanceCommand}" Padding="12,8" Background="#2563EB" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
