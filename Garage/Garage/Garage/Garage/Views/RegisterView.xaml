<Page x:Class="Garage.Views.RegisterView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="Création de compte">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Border Background="{DynamicResource SurfaceBrush}"
                CornerRadius="18"
                Padding="40"
                Width="420"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect Color="#888"
                                  BlurRadius="20"
                                  ShadowDepth="4"
                                  Opacity="0.35" />
            </Border.Effect>

            <StackPanel>
                <!-- Titre -->
                <TextBlock Text="Créer un compte"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0 0 0 25"/>

                <!-- Nom -->
                <Grid Margin="0 0 0 10">
                    <TextBox x:Name="LastNameBox"
                             Padding="10"
                             Height="40"
                             FontSize="14"
                             Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="BorderBrush" Value="#CCCCCC"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Background" Value="#FAFAFA"/>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <TextBlock Text="Nom"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="#888"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=LastNameBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- Prénom -->
                <Grid Margin="0 0 0 10">
                    <TextBox x:Name="FirstNameBox"
                             Padding="10"
                             Height="40"
                             FontSize="14"
                             Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="BorderBrush" Value="#CCCCCC"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Background" Value="#FAFAFA"/>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <TextBlock Text="Prénom"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="#888"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=FirstNameBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- Nom d'utilisateur -->
                <Grid Margin="0 0 0 10">
                    <TextBox x:Name="UsernameBox"
                             Padding="10"
                             Height="40"
                             FontSize="14"
                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="BorderBrush" Value="#CCCCCC"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Background" Value="#FAFAFA"/>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <TextBlock Text="Nom d'utilisateur"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="#888"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=UsernameBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- Mot de passe -->
                <Grid Margin="0 0 0 15">
                    <PasswordBox Padding="10"
                                 Height="40"
                                 FontSize="14"
                                 Name="PasswordBox"
                                 PasswordChanged="PasswordBox_OnPasswordChanged"/>
                    <TextBlock Text="Mot de passe"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="#888"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Password}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Password}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- Boutons -->
                <StackPanel Orientation="Vertical">
                    <Button Content="Créer le compte"
                            Command="{Binding RegisterCommand}"
                            Height="45"
                            Background="#27ae60"
                            Foreground="White"
                            FontWeight="Bold"
                            Margin="0 0 0 10"
                            Cursor="Hand"
                            BorderThickness="0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#27ae60"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="10"
                                                    Padding="10">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#219150"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#1b7a44"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="Retour à la connexion"
                            Command="{Binding CancelCommand}"
                            Height="35"
                            Background="Transparent"
                            Foreground="#3498db"
                            BorderBrush="Transparent"
                            Cursor="Hand"/>
                </StackPanel>

                <!-- Messages -->
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="Red"
                           Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}"
                           Margin="10"
                           TextAlignment="Center"/>

                <TextBlock Text="{Binding SuccessMessage}"
                           Foreground="Green"
                           Margin="0,5,0,0"
                           TextAlignment="Center"/>

            </StackPanel>
        </Border>
    </Grid>
</Page>
