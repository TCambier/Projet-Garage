<Page x:Class="Garage.Views.SettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:vm="clr-namespace:Garage.ViewModels"
      mc:Ignorable="d"
      Background="{DynamicResource AppBackgroundBrush}">

    <Page.DataContext>
        <vm:SettingsViewModel />
    </Page.DataContext>

    <Grid Margin="24">
        <Border Background="{DynamicResource SurfaceBrush}"
                CornerRadius="24"
                Effect="{DynamicResource SoftShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- === SIDEBAR === -->
                <Border Grid.Column="0"
                        Background="{DynamicResource SidebarBackgroundBrush}"
                        CornerRadius="24 0 0 24">
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Logo / titre appli -->
                        <StackPanel Orientation="Horizontal" Grid.Row="0" VerticalAlignment="Center">
                            <Border Width="32" Height="32" CornerRadius="16" Background="{DynamicResource SidebarBrandCircleBrush}" Margin="0,0,8,0">
                                <TextBlock Text="🚗" Foreground="{DynamicResource SidebarTextBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="16"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="AutoMaint Pro" Foreground="{DynamicResource SidebarTextBrush}" FontSize="18" FontWeight="Bold"/>
                                <TextBlock Text="Garage" Foreground="{DynamicResource SidebarMutedTextBrush}" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Menu -->
                        <StackPanel Grid.Row="1" Margin="0,32,0,0">
                            <Button Style="{StaticResource SidebarButton}" Command="{Binding NavigateToDashboardCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Dashboard"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButton}" Command="{Binding NavigateToVehiculesCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Véhicules"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButton}" Command="{Binding NavigateToEntretiensCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Entretiens"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButton}" Command="{Binding NavigateToStatistiquesCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Statistiques"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButton}" Background="{DynamicResource SidebarHoverBrush}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Paramètres"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Profil (placeholder) -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,16,0,0">
                            <Border Width="40" Height="40" CornerRadius="20" Background="{DynamicResource SidebarBrandCircleBrush}" Margin="0,0,10,0">
                                <TextBlock Text="?" Foreground="{DynamicResource SidebarTextBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="Utilisateur" Foreground="{DynamicResource SidebarTextBrush}" FontWeight="Bold"/>
                                <TextBlock Text="" Foreground="{DynamicResource SidebarMutedTextBrush}" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- === CONTENU PRINCIPAL === -->
                <Grid Grid.Column="1" Margin="32">
                    <TextBlock Text="Paramètres"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>

                    <Border Background="{DynamicResource SurfaceAltBrush}"
                            CornerRadius="18"
                            Padding="20"
                            Margin="0,24,0,0"
                            Effect="{DynamicResource SoftShadow}">
                        <StackPanel>
                            <TextBlock Text="Thème"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,8"/>

                            <CheckBox Content="Mode sombre"
                                      IsChecked="{Binding IsDarkMode, Mode=TwoWay}"
                                      Foreground="{DynamicResource TextPrimaryBrush}" />

                            <TextBlock Text="(désactive pour revenir en mode clair)"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="12"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
