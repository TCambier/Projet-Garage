<Page x:Class="Garage.Views.PiecesView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:vm="clr-namespace:Garage.ViewModels"
      mc:Ignorable="d"
      Background="{DynamicResource AppBackgroundBrush}">

    <Page.DataContext>
        <vm:PiecesViewModel />
    </Page.DataContext>

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Page.Resources>

    <!-- Conteneur principal avec overlay pour popup -->
    <Grid Margin="24">
        <!-- Contenu principal (carte blanche) -->
        <Border Background="{DynamicResource SurfaceBrush}"
                CornerRadius="24"
                Effect="{DynamicResource SoftShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- === SIDEBAR === -->
                <Border Grid.Column="0"
                        Background="{DynamicResource SidebarBackgroundBrush}"
                        CornerRadius="24 0 0 24">
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Logo appli -->
                        <StackPanel Orientation="Horizontal" Grid.Row="0" VerticalAlignment="Center">
                            <Border Width="32" Height="32" CornerRadius="16" Background="{DynamicResource SidebarBrandCircleBrush}" Margin="0,0,8,0">
                                <TextBlock Text="&#x1F697;" Foreground="{DynamicResource SidebarTextBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="16"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="AutoMaint Pro" Foreground="{DynamicResource SidebarTextBrush}" FontSize="18" FontWeight="Bold"/>
                                <TextBlock Text="Garage" Foreground="{DynamicResource SidebarMutedTextBrush}" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Menu -->
                        <StackPanel Grid.Row="1" Margin="0,32,0,0">
                            <Button Style="{StaticResource SidebarButton}"
                                    Command="{Binding NavigateToDashboardCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE80F;" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Dashboard"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButton}"
                                    Command="{Binding NavigateToVehiculesCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xEC49;" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="V&#233;hicules"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButton}"
                                    Command="{Binding NavigateToEntretiensCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE90F;" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Entretiens"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButton}" Background="#1f4068">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE82D;" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Pi&#232;ces"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7BA;" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Alertes"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButton}" Command="{Binding NavigateToStatistiquesCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE9F9;" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Statistiques"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButton}" Command="{Binding NavigateToSettingsCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE713;" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Param&#232;tres"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Profil -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,16,0,0">
                            <Border Width="40" Height="40" CornerRadius="20" Background="{DynamicResource SidebarBrandCircleBrush}" Margin="0,0,10,0">
                                <TextBlock Text="{Binding UserInitials}" Foreground="{DynamicResource SidebarTextBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="{Binding UserFullName}" Foreground="{DynamicResource SidebarTextBrush}" FontWeight="Bold"/>
                                <TextBlock Text="{Binding UserStatus}" Foreground="{DynamicResource SidebarMutedTextBrush}" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- === CONTENU PRINCIPAL === -->
                <Grid Grid.Column="1" Margin="32">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Barre de titre + bouton ajouter -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Pi&#232;ces"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>

                        <Button Grid.Column="1"
                                Content="Ajouter une pi&#232;ce"
                                Command="{Binding AddPieceCommand}"
                                Background="#2563EB"
                                Foreground="White"
                                Padding="12 6"
                                Margin="16 0 8 0"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Cursor="Hand"/>
                    </Grid>

                    <!-- Liste des pièces -->
                    <Border Grid.Row="1"
                            Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="18"
                            Margin="0,24,0,16"
                            Effect="{DynamicResource SoftShadow}">
                        <ListView ItemsSource="{Binding Pieces}"
                                  SelectedItem="{Binding SelectedPiece, Mode=TwoWay}"
                                  BorderThickness="0"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                            <ListView.Resources>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Margin" Value="0 4"/>
                                    <Setter Property="Padding" Value="16 12"/>
                                    <Setter Property="Background" Value="{DynamicResource ListItemBackgroundBrush}"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource ListItemHoverBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource ListItemSelectedBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListView.Resources>

                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Libell&#233;" Width="300">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Libelle}" FontWeight="SemiBold"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="Prix unitaire (&#8364;)" Width="200">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Prix_Unite, StringFormat={}{0:N2} &#8364;}" HorizontalAlignment="Right"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="Stock disponible" Width="180">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Nb_Piece}" HorizontalAlignment="Center"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <!-- Boutons d'actions -->
                                    <GridViewColumn Header="Actions" Width="200">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <Button Content="Modifier"
                                                            Command="{Binding DataContext.EditPieceCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                            CommandParameter="{Binding}"
                                                            Background="#2563EB"
                                                            Foreground="White"
                                                            Padding="8 4"
                                                            Margin="0 0 8 0"
                                                            BorderThickness="0"
                                                            Cursor="Hand"/>
                                                    <Button Content="Supprimer"
                                                            Command="{Binding DataContext.DeletePieceCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                            CommandParameter="{Binding}"
                                                            Background="#DC2626"
                                                            Foreground="White"
                                                            Padding="8 4"
                                                            Margin="0 0 0 0"
                                                            BorderThickness="0"
                                                            Cursor="Hand"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Border>

                    <!-- D&#233;tails pi&#232;ce s&#233;lectionn&#233;e -->
                    <Border Grid.Row="2"
                            Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="18"
                            Padding="24"
                            Margin="0,0,0,0"
                            Effect="{DynamicResource SoftShadow}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="D&#233;tails de la pi&#232;ce" FontWeight="Bold" FontSize="16" Margin="0,0,0,16"/>
                                <TextBlock Text="Libell&#233;" Foreground="#6B7280" FontSize="12" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding SelectedPiece.Libelle}" FontWeight="Bold" FontSize="16" Margin="0,0,0,12"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Prix unitaire" Foreground="#6B7280" FontSize="12" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding SelectedPiece.Prix_Unite, StringFormat={}{0:N2} &#8364;}" FontWeight="Bold" FontSize="18" Margin="0,0,0,12"/>

                                <TextBlock Text="Stock disponible" Foreground="#6B7280" FontSize="12" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding SelectedPiece.Nb_Piece}" FontWeight="Bold" FontSize="18" Margin="0,0,0,12"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- === POPUP AJOUT PI&#200;CE === -->
        <Grid Visibility="{Binding IsAddDialogOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Rectangle Fill="{DynamicResource OverlayBrush}" />
            <Border Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="16"
                    Padding="24"
                    Width="450"
                    MaxHeight="400"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Effect="{DynamicResource SoftShadow}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Nouvelle pi&#232;ce" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                        <StackPanel Grid.Row="1" Margin="0,0,0,20">
                            <!-- Libell&#233; -->
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Libell&#233; *" Foreground="#374151" FontWeight="Medium" Margin="0,0,0,4"/>
                                <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8">
                                    <TextBox Text="{Binding NewPiece.Libelle, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="12 10" BorderThickness="0"/>
                                </Border>
                            </StackPanel>

                            <!-- Prix unitaire -->
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Prix unitaire (&#8364;) *" Foreground="#374151" FontWeight="Medium" Margin="0,0,0,4"/>
                                <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8">
                                    <TextBox Text="{Binding NewPiece.Prix_Unite, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="12 10" BorderThickness="0"/>
                                </Border>
                            </StackPanel>

                            <!-- Nombre de pi&#232;ces -->
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Stock disponible *" Foreground="#374151" FontWeight="Medium" Margin="0,0,0,4"/>
                                <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8">
                                    <TextBox Text="{Binding NewPiece.Nb_Piece, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="12 10" BorderThickness="0"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Annuler" Command="{Binding CancelNewPieceCommand}" Margin="0,0,12,0" Padding="12,8" Background="Transparent" BorderBrush="#D1D5DB" Foreground="#374151"/>
                            <Button Content="Enregistrer" Command="{Binding SaveNewPieceCommand}" Padding="12,8" Background="#2563EB" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- === POPUP EDITION PI&#200;CE === -->
        <Grid Visibility="{Binding IsEditDialogOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Rectangle Fill="{DynamicResource OverlayBrush}" />
            <Border Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="16"
                    Padding="24"
                    Width="450"
                    MaxHeight="400"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Effect="{DynamicResource SoftShadow}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Modifier la pi&#232;ce" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                        <StackPanel Grid.Row="1" Margin="0,0,0,20">
                            <!-- Libell&#233; -->
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Libell&#233; *" Foreground="#374151" FontWeight="Medium" Margin="0,0,0,4"/>
                                <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8">
                                    <TextBox Text="{Binding EditPiece.Libelle, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="12 10" BorderThickness="0"/>
                                </Border>
                            </StackPanel>

                            <!-- Prix unitaire -->
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Prix unitaire (&#8364;) *" Foreground="#374151" FontWeight="Medium" Margin="0,0,0,4"/>
                                <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8">
                                    <TextBox Text="{Binding EditPiece.Prix_Unite, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="12 10" BorderThickness="0"/>
                                </Border>
                            </StackPanel>

                            <!-- Nombre de pi&#232;ces -->
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Stock disponible *" Foreground="#374151" FontWeight="Medium" Margin="0,0,0,4"/>
                                <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8">
                                    <TextBox Text="{Binding EditPiece.Nb_Piece, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="12 10" BorderThickness="0"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Annuler" Command="{Binding CancelEditPieceCommand}" Margin="0,0,12,0" Padding="12,8" Background="Transparent" BorderBrush="#D1D5DB" Foreground="#374151"/>
                            <Button Content="Enregistrer" Command="{Binding SaveEditPieceCommand}" Padding="12,8" Background="#2563EB" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
