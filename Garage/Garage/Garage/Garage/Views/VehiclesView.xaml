<Page x:Class="Garage.Views.VehiclesView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:vm="clr-namespace:Garage.ViewModels"
      mc:Ignorable="d"
      Background="{DynamicResource AppBackgroundBrush}">

    <Page.DataContext>
        <vm:VehiclesViewModel />
    </Page.DataContext>

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Page.Resources>

    <!-- Conteneur principal avec overlay pour popup -->
    <Grid Margin="24">
        <!-- Contenu principal (carte blanche) -->
        <Border Background="{DynamicResource SurfaceBrush}"
                CornerRadius="24"
                Effect="{DynamicResource SoftShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- === SIDEBAR === -->
                <Border Grid.Column="0"
                        Background="{DynamicResource SidebarBackgroundBrush}"
                        CornerRadius="24 0 0 24">
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Logo appli -->
                        <StackPanel Orientation="Horizontal" Grid.Row="0" VerticalAlignment="Center">
                            <Border Width="32" Height="32" CornerRadius="16" Background="{DynamicResource SidebarBrandCircleBrush}" Margin="0,0,8,0">
                                <TextBlock Text="🚗" Foreground="{DynamicResource SidebarTextBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="16"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="AutoMaint Pro" Foreground="{DynamicResource SidebarTextBrush}" FontSize="18" FontWeight="Bold"/>
                                <TextBlock Text="Garage" Foreground="{DynamicResource SidebarMutedTextBrush}" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Menu -->
                        <StackPanel Grid.Row="1" Margin="0,32,0,0">
                            <Button Style="{StaticResource SidebarButton}"
                                    Command="{Binding NavigateToDashboardCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Dashboard"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButton}" Background="#1f4068">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Véhicules"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButton}"
                                    Command="{Binding NavigateToEntretiensCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Entretiens"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Alertes"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButton}" Command="{Binding NavigateToStatistiquesCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Statistiques"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButton}" Command="{Binding NavigateToSettingsCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Paramètres"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Profil -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,16,0,0">
                            <Border Width="40" Height="40" CornerRadius="20" Background="{DynamicResource SidebarBrandCircleBrush}" Margin="0,0,10,0">
                                <TextBlock Text="JD" Foreground="{DynamicResource SidebarTextBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="Jean Dupont" Foreground="{DynamicResource SidebarTextBrush}" FontWeight="Bold"/>
                                <TextBlock Text="Patron" Foreground="{DynamicResource SidebarMutedTextBrush}" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- === CONTENU PRINCIPAL RESPONSIVE === -->
                <Grid Grid.Column="1" Margin="32">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Barre titre -->
                        <RowDefinition Height="*"/>
                        <!-- 👈 ListView prend TOUT l'espace restant -->
                        <RowDefinition Height="Auto"/>
                        <!-- Détails -->
                    </Grid.RowDefinitions>

                    <!-- Barre de titre + boutons -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Véhicules"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>

                        <Button Grid.Column="1"
                                Content="Ajouter un véhicule"
                                Command="{Binding AddVehicleCommand}"
                                Background="#2563EB"
                                Foreground="White"
                                Padding="12 6"
                                Margin="16 0 8 0"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Cursor="Hand"/>

                    </Grid>

                    <!-- 👈 LISTE RESPONSIVE : Border simple + ListView avec * -->
                    <Border Grid.Row="1"
                            Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="18"
                            Margin="0,24,0,16"
                            Effect="{DynamicResource SoftShadow}">
                        <ListView ItemsSource="{Binding Vehicles}"
                                  SelectedItem="{Binding SelectedVehicle, Mode=TwoWay}"
                                  BorderThickness="0"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                            <ListView.Resources>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Margin" Value="0 4"/>
                                    <Setter Property="Padding" Value="16 12"/>
                                    <Setter Property="Background" Value="{DynamicResource ListItemBackgroundBrush}"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource ListItemHoverBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource ListItemSelectedBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListView.Resources>

                            <ListView.View>
                                <GridView>
                                    <!-- 👈 Colonnes élargies pour mieux occuper l'espace -->
                                    <GridViewColumn Header="Immatriculation" Width="220">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Immatriculation}" FontWeight="SemiBold"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="Marque" Width="180">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Marque}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="Modèle" Width="220">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Modele}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="Année" Width="120">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Annee}" HorizontalAlignment="Center"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="Km" Width="120">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Kilometrage, StringFormat={}{0:N0}}" HorizontalAlignment="Right"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <!-- Boutons d'actions -->
                                    <GridViewColumn Header="Actions" Width="200">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <Button Content="Modifier"
                                                            Command="{Binding DataContext.EditVehicleCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                            CommandParameter="{Binding}"
                                                            Background="#2563EB"
                                                            Foreground="White"
                                                            Padding="8 4"
                                                            Margin="0 0 8 0"
                                                            BorderThickness="0"
                                                            Cursor="Hand"/>
                                                    <Button Content="Supprimer"
                                                            Command="{Binding DataContext.DeleteVehicleCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                            CommandParameter="{Binding}"
                                                            Background="#DC2626"
                                                            Foreground="White"
                                                            Padding="8 4"
                                                            Margin="0 0 0 0"
                                                            BorderThickness="0"
                                                            Cursor="Hand"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Border>

                    <!-- Détails véhicule -->
                    <Border Grid.Row="2"
                            Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="18"
                            Padding="24"
                            Margin="0,0,0,0"
                            Effect="{DynamicResource SoftShadow}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Détails du véhicule" FontWeight="Bold" FontSize="16" Margin="0,0,0,16"/>
                                <TextBlock Text="Immatriculation" Foreground="#6B7280" FontSize="12" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding SelectedVehicle.Immatriculation}" FontWeight="Bold" FontSize="16" Margin="0,0,0,12"/>

                                <TextBlock Text="Marque" Foreground="#6B7280" FontSize="12" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding SelectedVehicle.Marque}" FontWeight="Bold" FontSize="16" Margin="0,0,0,12"/>

                                <TextBlock Text="Modèle" Foreground="#6B7280" FontSize="12" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding SelectedVehicle.Modele}" FontWeight="SemiBold" FontSize="14"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Kilométrage" Foreground="#6B7280" FontSize="12" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding SelectedVehicle.Kilometrage, StringFormat={}{0:N0}}" FontWeight="Bold" FontSize="18" Margin="0,0,0,12"/>

                                <TextBlock Text="Année" Foreground="#6B7280" FontSize="12" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding SelectedVehicle.Annee}" FontWeight="Bold" FontSize="18" Margin="0,0,0,12" HorizontalAlignment="Center"/>

                                <TextBlock Text="Statut" Foreground="#6B7280" FontSize="12" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding SelectedVehicle.Statut}" FontWeight="Bold" FontSize="16" Margin="0,0,0,12"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- === POPUP AJOUT VEHICULE === -->
        <Grid Visibility="{Binding IsAddDialogOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Rectangle Fill="{DynamicResource OverlayBrush}" />
            <Border Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="16"
                    Padding="24"
                    Width="450"
                    MaxHeight="500"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Effect="{DynamicResource SoftShadow}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Nouveau véhicule" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                        <StackPanel Grid.Row="1" Margin="0,0,0,20">
                            <!-- Immatriculation -->
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Immatriculation *" Foreground="#374151" FontWeight="Medium" Margin="0,0,0,4"/>
                                <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8">
                                    <TextBox Text="{Binding NewVehicle.Immatriculation, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="12 10" BorderThickness="0"/>
                                </Border>
                            </StackPanel>

                            <!-- Marque -->
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Marque *" Foreground="#374151" FontWeight="Medium" Margin="0,0,0,4"/>
                                <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8">
                                    <TextBox Text="{Binding NewVehicle.Marque, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="12 10" BorderThickness="0"/>
                                </Border>
                            </StackPanel>

                            <!-- Modèle -->
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Modèle" Foreground="#374151" FontWeight="Medium" Margin="0,0,0,4"/>
                                <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8">
                                    <TextBox Text="{Binding NewVehicle.Modele, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="12 10" BorderThickness="0"/>
                                </Border>
                            </StackPanel>

                            <!-- Année -->
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Année (ex: 2025) *" Foreground="#374151" FontWeight="Medium" Margin="0,0,0,4"/>
                                <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8">
                                    <TextBox Text="{Binding NewVehicle.Annee, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="12 10" BorderThickness="0"/>
                                </Border>
                            </StackPanel>

                            <!-- Kilométrage -->
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Kilométrage (km) *" Foreground="#374151" FontWeight="Medium" Margin="0,0,0,4"/>
                                <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8">
                                    <TextBox Text="{Binding NewVehicle.Kilometrage, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="12 10" BorderThickness="0"/>
                                </Border>
                            </StackPanel>

                            <!-- Utilisateur -->
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Utilisateur *" Foreground="#374151" FontWeight="Medium" Margin="0,0,0,4"/>
                                <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8">
                                    <ComboBox SelectedItem="{Binding SelectedUser, UpdateSourceTrigger=PropertyChanged}"
                                              ItemsSource="{Binding AvailableUsers}"
                                              DisplayMemberPath="PrenomNom"
                                              IsEditable="True"
                                              IsTextSearchEnabled="True"
                                              IsTextSearchCaseSensitive="False"
                                              StaysOpenOnEdit="True"
                                              TextSearch.TextPath="NomPrenom"
                                              FontSize="14" Padding="12 10" BorderThickness="0"/>
                                </Border>
                            </StackPanel>

                            <!-- Carburant -->
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Carburant *" Foreground="#374151" FontWeight="Medium" Margin="0,0,0,4"/>
                                <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8">
                                    <ComboBox SelectedItem="{Binding NewVehicle.Carburant, UpdateSourceTrigger=PropertyChanged}" ItemsSource="{Binding AvailableFuels}" FontSize="14" Padding="12 10" BorderThickness="0"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Annuler" Command="{Binding CancelNewVehicleCommand}" Margin="0,0,12,0" Padding="12,8" Background="Transparent" BorderBrush="#D1D5DB" Foreground="#374151"/>
                            <Button Content="Enregistrer" Command="{Binding SaveNewVehicleCommand}" Padding="12,8" Background="#2563EB" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- === POPUP EDITION VEHICULE === -->
        <Grid Visibility="{Binding IsEditDialogOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Rectangle Fill="{DynamicResource OverlayBrush}" />
            <Border Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="16"
                    Padding="24"
                    Width="450"
                    MaxHeight="500"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Effect="{DynamicResource SoftShadow}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Modifier le véhicule" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                        <StackPanel Grid.Row="1" Margin="0,0,0,20">
                            <!-- Immatriculation -->
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Immatriculation *" Foreground="#374151" FontWeight="Medium" Margin="0,0,0,4"/>
                                <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8">
                                    <TextBox Text="{Binding EditVehicle.Immatriculation, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="12 10" BorderThickness="0"/>
                                </Border>
                            </StackPanel>

                            <!-- Kilométrage -->
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Kilométrage (km) *" Foreground="#374151" FontWeight="Medium" Margin="0,0,0,4"/>
                                <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8">
                                    <TextBox Text="{Binding EditVehicle.Kilometrage, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="12 10" BorderThickness="0"/>
                                </Border>
                            </StackPanel>

                            <!-- Statut -->
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Statut *" Foreground="#374151" FontWeight="Medium" Margin="0,0,0,4"/>
                                <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8">
                                    <ComboBox SelectedItem="{Binding EditVehicle.Statut, UpdateSourceTrigger=PropertyChanged}"
                                              ItemsSource="{Binding AvailableStatuses}"
                                              FontSize="14" Padding="12 10" BorderThickness="0"/>
                                </Border>
                            </StackPanel>

                            <!-- Carburant -->
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Carburant *" Foreground="#374151" FontWeight="Medium" Margin="0,0,0,4"/>
                                <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8">
                                    <ComboBox SelectedItem="{Binding EditVehicle.Carburant, UpdateSourceTrigger=PropertyChanged}"
                                              ItemsSource="{Binding AvailableFuels}"
                                              FontSize="14" Padding="12 10" BorderThickness="0"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Annuler" Command="{Binding CancelEditVehicleCommand}" Margin="0,0,12,0" Padding="12,8" Background="Transparent" BorderBrush="#D1D5DB" Foreground="#374151"/>
                            <Button Content="Enregistrer" Command="{Binding SaveEditVehicleCommand}" Padding="12,8" Background="#2563EB" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
