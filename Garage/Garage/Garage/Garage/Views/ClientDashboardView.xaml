<Page x:Class="Garage.Views.ClientDashboardView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:h="clr-namespace:Garage.Helpers"
      mc:Ignorable="d"
      Background="{DynamicResource AppBackgroundBrush}">

    <Page.Resources>
        <h:StringToVisibilityConverter x:Key="StringToVisibility"/>
        <h:NullToVisibilityConverter x:Key="NullToVisibility"/>
    </Page.Resources>

    <Grid Margin="24">
        <Border Background="{DynamicResource SurfaceBrush}"
                CornerRadius="24"
                Effect="{DynamicResource SoftShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- === SIDEBAR === -->
                <Border Grid.Column="0"
                        Background="{DynamicResource SidebarBackgroundBrush}"
                        CornerRadius="24 0 0 24">
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Logo -->
                        <StackPanel Orientation="Horizontal" Grid.Row="0" VerticalAlignment="Center">
                            <Border Width="32" Height="32" CornerRadius="16"
                                    Background="{DynamicResource SidebarBrandCircleBrush}" Margin="0,0,8,0">
                                <TextBlock Text="🚗" Foreground="{DynamicResource SidebarTextBrush}"
                                           VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="16"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="AutoMaint Pro" Foreground="{DynamicResource SidebarTextBrush}"
                                           FontSize="18" FontWeight="Bold"/>
                                <TextBlock Text="Espace Client" Foreground="{DynamicResource SidebarMutedTextBrush}"
                                           FontSize="12"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Menu client (limité) -->
                        <StackPanel Grid.Row="1" Margin="0,32,0,0">
                            <Button Style="{StaticResource SidebarButton}" Command="{Binding RefreshCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE10F;" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Actualiser"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButton}" Command="{Binding LogoutCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE1E6;" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Déconnexion"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Profil en bas -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,16,0,0">
                            <Border Width="40" Height="40" CornerRadius="20"
                                    Background="{DynamicResource SidebarBrandCircleBrush}" Margin="0,0,10,0">
                                <TextBlock Text="{Binding UserInitials}"
                                           Foreground="{DynamicResource SidebarTextBrush}"
                                           VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="{Binding UserFullName}"
                                           Foreground="{DynamicResource SidebarTextBrush}" FontWeight="Bold"/>
                                <TextBlock Text="{Binding UserStatus}"
                                           Foreground="{DynamicResource SidebarMutedTextBrush}" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- === CONTENU PRINCIPAL === -->
                <Grid Grid.Column="1" Margin="32">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Cartes résumé -->
                        <RowDefinition Height="Auto"/>
                        <!-- Contenu : véhicules + entretiens -->
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Barre supérieure -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Mon Espace Client"
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <StackPanel Margin="0,0,12,0" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding UserFullName}" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Right"/>
                                <TextBlock Text="{Binding UserStatus}"
                                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                           HorizontalAlignment="Right"/>
                            </StackPanel>
                            <Border Width="40" Height="40" CornerRadius="20"
                                    Background="{DynamicResource AvatarBackgroundBrush}">
                                <TextBlock Text="{Binding UserInitials}" VerticalAlignment="Center"
                                           HorizontalAlignment="Center" FontWeight="Bold"
                                           Foreground="{DynamicResource AvatarTextBrush}"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Cartes résumé -->
                    <UniformGrid Grid.Row="1" Margin="0,24,0,0" Rows="1" Columns="3"
                                 HorizontalAlignment="Stretch" VerticalAlignment="Top">
                        <!-- Mes véhicules -->
                        <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="16"
                                Padding="24" Margin="0,0,16,0" MinHeight="130"
                                Effect="{DynamicResource SoftShadow}">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Mes Véhicules" FontSize="16" FontWeight="DemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding TotalVehicles}" FontSize="40" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Entretiens en cours -->
                        <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="16"
                                Padding="24" Margin="0,0,16,0" MinHeight="130"
                                Effect="{DynamicResource SoftShadow}">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="En cours d'entretien" FontSize="16" FontWeight="DemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding EntretiensEnCours}" FontSize="40" FontWeight="Bold"
                                           Foreground="#F59E0B" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Prochain entretien -->
                        <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="16"
                                Padding="24" MinHeight="130"
                                Effect="{DynamicResource SoftShadow}">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Prochain entretien" FontSize="16" FontWeight="DemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding ProchainEntretienLabel}" FontSize="22" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,6,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Zone principale : Véhicules + Entretiens -->
                    <Grid Grid.Row="2" Margin="0,24,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="1.8*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Liste des véhicules -->
                        <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}"
                                CornerRadius="18" Padding="16" Margin="0,0,16,0"
                                Effect="{DynamicResource SoftShadow}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Mes Véhicules" FontSize="18" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="8,0,0,12"/>

                                <ListBox Grid.Row="1"
                                         ItemsSource="{Binding Vehicles}"
                                         SelectedItem="{Binding SelectedVehicle}"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="12" Margin="0,4" CornerRadius="12"
                                                    Background="{DynamicResource SurfaceAltBrush}">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <!-- Immatriculation + Statut -->
                                                    <Grid Grid.Row="0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Immatriculation}"
                                                                   FontSize="16" FontWeight="Bold"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                        <Border Grid.Column="1" CornerRadius="8" Padding="8,4">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#DBEAFE"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding StatutAffiche}" Value="EnReparation">
                                                                            <Setter Property="Background" Value="#FEF3C7"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding StatutAffiche}" Value="HorsService">
                                                                            <Setter Property="Background" Value="#FEE2E2"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding StatutAffiche}" Value="En Cours">
                                                                            <Setter Property="Background" Value="#FEF3C7"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock FontSize="11" FontWeight="SemiBold">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Text" Value="En service"/>
                                                                        <Setter Property="Foreground" Value="#1D4ED8"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding StatutAffiche}" Value="EnReparation">
                                                                                <Setter Property="Text" Value="En réparation"/>
                                                                                <Setter Property="Foreground" Value="#92400E"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding StatutAffiche}" Value="HorsService">
                                                                                <Setter Property="Text" Value="Hors service"/>
                                                                                <Setter Property="Foreground" Value="#B91C1C"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding StatutAffiche}" Value="En Cours">
                                                                                <Setter Property="Text" Value="En cours"/>
                                                                                <Setter Property="Foreground" Value="#92400E"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>
                                                    </Grid>

                                                    <!-- Marque / Modèle -->
                                                    <TextBlock Grid.Row="1"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               FontSize="13" Margin="0,4,0,0">
                                                        <Run Text="{Binding Marque, Mode=OneWay}"/>
                                                        <Run Text=" "/>
                                                        <Run Text="{Binding Modele, Mode=OneWay}"/>
                                                        <Run Text=" ("/>
                                                        <Run Text="{Binding Annee, Mode=OneWay}"/>
                                                        <Run Text=")"/>
                                                    </TextBlock>

                                                    <!-- Km + Carburant -->
                                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4,0,0">
                                                        <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}">
                                                            <Run Text="{Binding Kilometrage, Mode=OneWay, StringFormat='{}{0:N0}'}"/>
                                                            <Run Text=" km"/>
                                                        </TextBlock>
                                                        <TextBlock Text="  •  " FontSize="12"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                        <TextBlock Text="{Binding Carburant}" FontSize="12"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <!-- Détail entretiens du véhicule sélectionné -->
                        <Border Grid.Column="1" Background="{DynamicResource SurfaceBrush}"
                                CornerRadius="18" Padding="16"
                                Effect="{DynamicResource SoftShadow}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Margin="8,0,0,12">
                                    <TextBlock FontSize="18" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}">
                                        <Run Text="Entretiens — "/>
                                        <Run Text="{Binding SelectedVehicle.Immatriculation, FallbackValue='Sélectionnez un véhicule', Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Liste des entretiens (lecture seule) -->
                                <ListView Grid.Row="1"
                                          ItemsSource="{Binding Maintenances}"
                                          BorderThickness="0"
                                          Background="Transparent"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="14" Margin="0,4" CornerRadius="12"
                                                    Background="{DynamicResource SurfaceAltBrush}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0">
                                                        <!-- Type + Statut -->
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Type}" FontSize="15"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                            <Border CornerRadius="8" Padding="8,2" Margin="10,0,0,0"
                                                                    VerticalAlignment="Center">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="#DBEAFE"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Statut}" Value="En Cours">
                                                                                <Setter Property="Background" Value="#FEF3C7"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Statut}" Value="En cours">
                                                                                <Setter Property="Background" Value="#FEF3C7"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Statut}" Value="Terminé">
                                                                                <Setter Property="Background" Value="#D1FAE5"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock Text="{Binding Statut}" FontSize="11"
                                                                           FontWeight="SemiBold">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="#1D4ED8"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Statut}" Value="En Cours">
                                                                                    <Setter Property="Foreground" Value="#92400E"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Statut}" Value="En cours">
                                                                                    <Setter Property="Foreground" Value="#92400E"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Statut}" Value="Terminé">
                                                                                    <Setter Property="Foreground" Value="#065F46"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Border>
                                                        </StackPanel>

                                                        <!-- Date -->
                                                        <TextBlock FontSize="13" Margin="0,4,0,0"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}">
                                                            <Run Text="Date : "/>
                                                            <Run Text="{Binding DateIntervention, StringFormat='dd/MM/yyyy', Mode=OneWay}"/>
                                                        </TextBlock>

                                                        <!-- Kilométrage -->
                                                        <TextBlock FontSize="12" Margin="0,2,0,0"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}">
                                                            <Run Text="Km : "/>
                                                            <Run Text="{Binding Kilometrage, Mode=OneWay, StringFormat='{}{0:N0}'}"/>
                                                        </TextBlock>

                                                        <!-- Pièces utilisées -->
                                                        <TextBlock FontSize="12" Margin="0,2,0,0"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   TextWrapping="Wrap"
                                                                   Visibility="{Binding Pieces, Converter={StaticResource StringToVisibility}}">
                                                            <Run Text="Pièces : "/>
                                                            <Run Text="{Binding Pieces, Mode=OneWay}"/>
                                                        </TextBlock>
                                                    </StackPanel>

                                                    <!-- Prix à droite -->
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                                                HorizontalAlignment="Right" Margin="12,0,0,0">
                                                        <TextBlock FontSize="18" FontWeight="Bold"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   HorizontalAlignment="Right">
                                                            <Run Text="{Binding Prix, StringFormat='{}{0:F2}', Mode=OneWay}"/>
                                                            <Run Text=" €"/>
                                                        </TextBlock>
                                                        <TextBlock FontSize="11"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   HorizontalAlignment="Right">
                                                            <Run Text="Coût : "/>
                                                            <Run Text="{Binding Cout, StringFormat='{}{0:F2}', Mode=OneWay}"/>
                                                            <Run Text=" €"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>

                                <!-- Message si aucun véhicule sélectionné -->
                                <TextBlock Grid.Row="1"
                                           Text="Sélectionnez un véhicule pour voir ses entretiens"
                                           FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="{Binding SelectedVehicle, Converter={StaticResource NullToVisibility}}"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
