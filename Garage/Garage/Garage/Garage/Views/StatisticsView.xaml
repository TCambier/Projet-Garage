<Page x:Class="Garage.Views.StatisticsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:vm="clr-namespace:Garage.ViewModels"
      mc:Ignorable="d"
      Background="{DynamicResource AppBackgroundBrush}">

    <Page.DataContext>
        <vm:StatisticsViewModel />
    </Page.DataContext>

    <Grid Margin="24">
        <Border Background="{DynamicResource SurfaceBrush}"
                CornerRadius="24"
                Effect="{DynamicResource SoftShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- === SIDEBAR === -->
                <Border Grid.Column="0"
                        Background="{DynamicResource SidebarBackgroundBrush}"
                        CornerRadius="24 0 0 24">
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Logo appli -->
                        <StackPanel Orientation="Horizontal" Grid.Row="0" VerticalAlignment="Center">
                            <Border Width="32" Height="32" CornerRadius="16" Background="{DynamicResource SidebarBrandCircleBrush}" Margin="0,0,8,0">
                                <TextBlock Text="🚗" Foreground="{DynamicResource SidebarTextBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="16"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="AutoMaint Pro" Foreground="{DynamicResource SidebarTextBrush}" FontSize="18" FontWeight="Bold"/>
                                <TextBlock Text="Garage" Foreground="{DynamicResource SidebarMutedTextBrush}" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Menu -->
                        <StackPanel Grid.Row="1" Margin="0,32,0,0">
                            <Button Style="{StaticResource SidebarButton}"
                                    Command="{Binding NavigateToDashboardCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE80F;" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Dashboard"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButton}"
                                    Command="{Binding NavigateToVehiculesCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xEC49;" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Véhicules"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButton}"
                                    Command="{Binding NavigateToEntretiensCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE90F;" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Entretiens"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButton}" Command="{Binding NavigateToPiecesCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE82D;" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Pièces"/>
                                </StackPanel>
                            </Button>
                            <!-- Bouton Alertes (même style que les autres pages) -->
                            <Button Style="{StaticResource SidebarButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7BA;" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Alertes"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButton}" Background="#1f4068">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE9F9;" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Statistiques"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButton}" Command="{Binding NavigateToSettingsCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE713;" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Paramètres"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Profil (statique comme sur Véhicules/Entretiens) -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,16,0,0">
                            <Border Width="40" Height="40" CornerRadius="20" Background="{DynamicResource SidebarBrandCircleBrush}" Margin="0,0,10,0">
                                <TextBlock Text="JD" Foreground="{DynamicResource SidebarTextBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="Jean Dupont" Foreground="{DynamicResource SidebarTextBrush}" FontWeight="Bold"/>
                                <TextBlock Text="Patron" Foreground="{DynamicResource SidebarMutedTextBrush}" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- === CONTENU PRINCIPAL === -->
                <Grid Grid.Column="1" Margin="32">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Titre -->
                    <TextBlock Grid.Row="0"
                               Text="Statistiques"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>

                    <!-- Ligne du haut : coûts mensuels + top 5 véhicules -->
                    <Grid Grid.Row="1" Margin="0,24,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Coût total par mois (12 mois) -->
                        <Border Grid.Column="0" Background="{DynamicResource SurfaceAltBrush}" CornerRadius="18" Padding="20" Margin="0,0,24,0" Effect="{DynamicResource SoftShadow}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Orientation="Horizontal" Grid.Row="0" VerticalAlignment="Center">
                                    <StackPanel>
                                        <TextBlock Text="Coût total des interventions (12 derniers mois)" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding TotalYearCost, StringFormat={}{0:N0} €}" Foreground="#6B7280" FontSize="12"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Histogramme des coûts mensuels -->
                                <Grid Grid.Row="1" Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="56"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.ColumnSpan="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="12"/>

                                    <!-- Axe Y (valeurs en €) -->
                                    <Grid Grid.Row="0" Grid.Column="0" Margin="12" VerticalAlignment="Stretch">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="{Binding AxisMaxValue, StringFormat={}{0:N0} €}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock Grid.Row="1" Text="{Binding AxisMidValue, StringFormat={}{0:N0} €}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Row="2" Text="0 €" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </Grid>

                                    <ItemsControl Grid.Row="0" Grid.Column="1" ItemsSource="{Binding MonthlyStats}" Margin="12" VerticalAlignment="Stretch">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="4,0" VerticalAlignment="Bottom">
                                                    <Border Background="#2563EB" Width="16" CornerRadius="6,6,0,0" Height="{Binding CostBarHeight}"/>
                                                    <TextBlock Text="{Binding Label}" FontSize="10" Foreground="#6B7280" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Légende mois -->
                                    <!-- déjà incluse sous chaque barre via Label -->
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Top 5 véhicules les plus coûteux -->
                        <Border Grid.Column="1" Background="{DynamicResource SurfaceAltBrush}" CornerRadius="18" Padding="20" Effect="{DynamicResource SoftShadow}">
                            <StackPanel>
                                <TextBlock Text="Top 5 véhicules les plus coûteux" FontWeight="Bold" Margin="0,0,0,12"/>
                                <ItemsControl ItemsSource="{Binding TopVehicleCosts}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,4">
                                                <TextBlock Text="{Binding Label}" FontSize="12" FontWeight="SemiBold"/>
                                                <Grid Margin="0,4,0,0">
                                                    <Border Background="#DBEAFE" Height="10" CornerRadius="5">
                                                        <Border Background="#2563EB" Height="10" CornerRadius="5" Width="{Binding BarWidth}" HorizontalAlignment="Left"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding TotalCost, StringFormat={}{0:N0} €}" FontSize="11" Foreground="#4B5563" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                </Grid>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Ligne du bas : graphique d'évolution coûts vs bénéfices -->
                    <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="18" Padding="20" Margin="0,24,0,0" Effect="{DynamicResource SoftShadow}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Évolution coûts / bénéfices" FontWeight="Bold"/>
                                <StackPanel Orientation="Horizontal" Margin="24,0,0,0" VerticalAlignment="Center">
                                    <Rectangle Width="12" Height="12" Fill="#2563EB" RadiusX="3" RadiusY="3" Margin="0,0,6,0"/>
                                    <TextBlock Text="Coûts" FontSize="11" Foreground="#4B5563" Margin="0,0,12,0"/>
                                    <Rectangle Width="12" Height="12" Fill="#16A34A" RadiusX="3" RadiusY="3" Margin="0,0,6,0"/>
                                    <TextBlock Text="Bénéfices" FontSize="11" Foreground="#4B5563"/>
                                </StackPanel>
                            </StackPanel>

                            <Grid Grid.Row="1" Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.ColumnSpan="2" Background="{DynamicResource SurfaceAltBrush}" CornerRadius="12"/>

                                <!-- Axe Y (valeurs en €) -->
                                <Grid Grid.Column="0" Margin="12" VerticalAlignment="Stretch">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="{Binding AxisMaxValue, StringFormat={}{0:N0} €}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Row="1" Text="{Binding AxisMidValue, StringFormat={}{0:N0} €}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Text="0 €" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </Grid>

                                <Canvas Grid.Column="1" Margin="12" IsHitTestVisible="False">
                                    <Polyline Points="{Binding CostLinePoints}"
                                              Stroke="#2563EB" StrokeThickness="3" StrokeLineJoin="Round" />
                                    <Polyline Points="{Binding ProfitLinePoints}"
                                              Stroke="#16A34A" StrokeThickness="3" StrokeLineJoin="Round" />
                                </Canvas>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
