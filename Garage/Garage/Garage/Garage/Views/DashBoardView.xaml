<Page x:Class="Garage.Views.DashboardView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:h="clr-namespace:Garage.Helpers"
      mc:Ignorable="d"
      Background="{DynamicResource AppBackgroundBrush}">

    <Page.Resources>
        <h:ChartPointsConverter x:Key="ChartPointsConverter" />
    </Page.Resources>

    <!-- Conteneur principal avec "carte" blanche au centre -->
    <Grid Margin="24">
        <Border Background="{DynamicResource SurfaceBrush}"
                CornerRadius="24"
                Effect="{DynamicResource SoftShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- === SIDEBAR === -->
                <Border Grid.Column="0"
                        Background="{DynamicResource SidebarBackgroundBrush}"
                        CornerRadius="24 0 0 24">
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Logo / titre appli -->
                        <StackPanel Orientation="Horizontal" Grid.Row="0" VerticalAlignment="Center">
                            <Border Width="32" Height="32" CornerRadius="16" Background="{DynamicResource SidebarBrandCircleBrush}" Margin="0,0,8,0">
                                <TextBlock Text="🚗" Foreground="{DynamicResource SidebarTextBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="16"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="AutoMaint Pro" Foreground="{DynamicResource SidebarTextBrush}" FontSize="18" FontWeight="Bold"/>
                                <TextBlock Text="Garage" Foreground="{DynamicResource SidebarMutedTextBrush}" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Menu -->
                        <StackPanel Grid.Row="1" Margin="0,32,0,0">
                            <Button Style="{StaticResource SidebarButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Dashboard"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButton}" Command="{Binding NavigateToVehiculesCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Véhicules"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButton}" Command="{Binding NavigateToEntretiensCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Entretiens"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Alertes"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButton}" Command="{Binding NavigateToStatistiquesCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Statistiques"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SidebarButton}" Command="{Binding NavigateToSettingsCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="" FontSize="18" Margin="0,0,12,0"/>
                                    <TextBlock Text="Paramètres"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Profil utilisateur en bas (dynamique) -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,16,0,0">
                            <Border Width="40" Height="40" CornerRadius="20" Background="{DynamicResource SidebarBrandCircleBrush}" Margin="0,0,10,0">
                                <TextBlock Text="{Binding UserInitials}" Foreground="{DynamicResource SidebarTextBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="{Binding UserFullName}" Foreground="{DynamicResource SidebarTextBrush}" FontWeight="Bold"/>
                                <TextBlock Text="{Binding UserStatus}" Foreground="{DynamicResource SidebarMutedTextBrush}" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- === CONTENU PRINCIPAL === -->
                <Grid Grid.Column="1" Margin="32">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Cartes du haut : hauteur "naturelle" (évite qu'elles deviennent trop grandes) -->
                        <RowDefinition Height="Auto"/>
                        <!-- Le reste prend l'espace (plein écran) -->
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Barre supérieure avec titre + profil -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Tableau de bord"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <StackPanel Margin="0,0,12,0" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding UserFullName}" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Right"/>
                                <TextBlock Text="{Binding UserStatus}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" HorizontalAlignment="Right"/>
                            </StackPanel>
                            <Border Width="40" Height="40" CornerRadius="20" Background="{DynamicResource AvatarBackgroundBrush}">
                                <TextBlock Text="{Binding UserInitials}" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Foreground="{DynamicResource AvatarTextBrush}"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Cartes de stats (compactes) -->
                    <UniformGrid Grid.Row="1" Margin="0,24,0,0" Rows="1" Columns="3" HorizontalAlignment="Stretch" VerticalAlignment="Top">
                        <!-- Véhicules en service -->
                        <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="16" Padding="24" Margin="0,0,16,0" MinHeight="208" MaxHeight="280" Effect="{DynamicResource SoftShadow}">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Véhicules enregistré" FontSize="35" FontWeight="DemiBold" />
                                <TextBlock Text="{Binding Stats.VehiclesInService}" FontSize="50"  Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Interventions ce mois -->
                        <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="16" Padding="24" Margin="0,0,16,0" MinHeight="208" MaxHeight="280" Effect="{DynamicResource SoftShadow}">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Interventions ce mois" FontSize="35" FontWeight="DemiBold" />
                                <TextBlock Text="{Binding Stats.InterventionsThisMonth}" FontSize="50" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Alertes en attente -->
                        <Border Background="{DynamicResource DangerSurfaceBrush}" CornerRadius="16" Padding="24" MinHeight="208" MaxHeight="280" Effect="{DynamicResource SoftShadow}">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Alertes en attente" Foreground="{DynamicResource DangerTextBrush}" FontSize="35" FontWeight="DemiBold" />
                                <TextBlock Text="{Binding Stats.PendingAlerts}" FontSize="50"  Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Graphique + alertes urgentes -->
                    <Grid Grid.Row="2" Margin="0,24,0,0" VerticalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Carte graphique -->
                        <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}" CornerRadius="18" Padding="16" Margin="0,0,24,0" MinHeight="608" MaxHeight="860" VerticalAlignment="Top" Effect="{DynamicResource SoftShadow}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Nombre d'interventions par mois" FontSize="35" FontWeight="SemiBold"/>

                                <!-- Graphique (dynamique : valeurs depuis la BD) -->
                                <Grid Grid.Row="1" Margin="0,12,0,0">
                                    <Grid.RowDefinitions>
                                        <!-- zone graphique -->
                                        <RowDefinition Height="Auto"/>
                                        <!-- labels mois -->
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Zone graphique avec graduation à gauche -->
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Graduation Y -->
                                        <ItemsControl Grid.Column="0" ItemsSource="{Binding YAxisLabels}" Height="515" VerticalAlignment="Top" Margin="0,10,8,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Rows="5" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" HorizontalAlignment="Right" Foreground="#9CA3AF" FontSize="11" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Plot -->
                                        <Grid Grid.Column="1" MinHeight="450" MaxHeight="660" VerticalAlignment="Top">
                                            <!-- fond -->
                                            <Border Background="#F9FAFB" CornerRadius="12"/>

                                            <Canvas x:Name="PlotArea" Margin="10,10">
                                                <!-- courbe (points calculés selon la taille réelle du canvas) -->
                                                <Polyline Stroke="#2563EB" StrokeThickness="3" StrokeLineJoin="Round" IsHitTestVisible="False">
                                                    <Polyline.Points>
                                                        <MultiBinding Converter="{StaticResource ChartPointsConverter}">
                                                            <Binding Path="InterventionsByMonth" />
                                                            <Binding ElementName="PlotArea" Path="ActualWidth" />
                                                            <Binding ElementName="PlotArea" Path="ActualHeight" />
                                                        </MultiBinding>
                                                    </Polyline.Points>
                                                </Polyline>

                                                <!-- points -->
                                                <ItemsControl IsHitTestVisible="False" Width="{Binding ElementName=PlotArea, Path=ActualWidth}" Height="{Binding ElementName=PlotArea, Path=ActualHeight}">
                                                    <ItemsControl.ItemsSource>
                                                        <MultiBinding Converter="{StaticResource ChartPointsConverter}">
                                                            <Binding Path="InterventionsByMonth" />
                                                            <Binding ElementName="PlotArea" Path="ActualWidth" />
                                                            <Binding ElementName="PlotArea" Path="ActualHeight" />
                                                        </MultiBinding>
                                                    </ItemsControl.ItemsSource>
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <Canvas />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Ellipse Width="8" Height="8" Fill="#2563EB" Canvas.Left="{Binding X}" Canvas.Top="{Binding Y}">
                                                                <Ellipse.RenderTransform>
                                                                    <TranslateTransform X="-4" Y="-4" />
                                                                </Ellipse.RenderTransform>
                                                            </Ellipse>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Canvas>
                                        </Grid>
                                    </Grid>

                                    <!-- labels mois (UniformGrid => espacement égal, aligné au graphique) -->
                                    <UniformGrid Grid.Row="1" Columns="12" Margin="44,8,0,0">
                                        <TextBlock Text="Jan" Foreground="#9CA3AF" FontSize="11" TextAlignment="Center" />
                                        <TextBlock Text="Févr" Foreground="#9CA3AF" FontSize="11" TextAlignment="Center" />
                                        <TextBlock Text="Mars" Foreground="#9CA3AF" FontSize="11" TextAlignment="Center" />
                                        <TextBlock Text="Avr" Foreground="#9CA3AF" FontSize="11" TextAlignment="Center" />
                                        <TextBlock Text="Mai" Foreground="#9CA3AF" FontSize="11" TextAlignment="Center" />
                                        <TextBlock Text="Juin" Foreground="#9CA3AF" FontSize="11" TextAlignment="Center" />
                                        <TextBlock Text="Juil" Foreground="#9CA3AF" FontSize="11" TextAlignment="Center" />
                                        <TextBlock Text="Août" Foreground="#9CA3AF" FontSize="11" TextAlignment="Center" />
                                        <TextBlock Text="Sept" Foreground="#9CA3AF" FontSize="11" TextAlignment="Center" />
                                        <TextBlock Text="Oct" Foreground="#9CA3AF" FontSize="11" TextAlignment="Center" />
                                        <TextBlock Text="Nov" Foreground="#9CA3AF" FontSize="11" TextAlignment="Center" />
                                        <TextBlock Text="Déc" Foreground="#9CA3AF" FontSize="11" TextAlignment="Center" />
                                    </UniformGrid>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Carte Alertes urgentes -->
                        <Border Grid.Column="1" Background="{DynamicResource SurfaceBrush}" CornerRadius="18" Padding="16" MinHeight="608" MaxHeight="609" VerticalAlignment="Top" Effect="{DynamicResource SoftShadow}" Height="233">
                            <StackPanel>
                                <TextBlock Text="Alertes en attente" FontSize="35" FontWeight="DemiBold" Margin="8 0 0 20"/>

                                <ItemsControl ItemsSource="{Binding UrgentAlerts}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0 13">
                                                <Border Width="50" Height="50" CornerRadius="14" Background="#FEE2E2" Margin="0,0,25,0">
                                                    <!-- Icône danger (Unicode warning sign) -->
                                                    <TextBlock Text="⚠" FontSize="30" Foreground="#B91C1C" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                                </Border>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="18"/>
                                                    <TextBlock Text="{Binding Vehicle}" Foreground="#6B7280" FontSize="15"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
